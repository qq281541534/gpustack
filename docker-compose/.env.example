# ============================================================
# GPUStack Docker Compose 环境变量配置
# ============================================================
# 使用方法：
#   1. cp .env.example .env
#   2. 编辑 .env，按需填写参数
#   3. docker compose -f docker-compose.server.yaml up -d
#
# 注意：
#   - 所有 GPUSTACK_ 前缀的变量会被 GPUStack 服务自动读取
#   - SSO 变量留空或不填 = 禁用 SSO，只显示本地登录
#   - 敏感信息（Client Secret 等）请妥善保管，勿提交到 Git
# ============================================================


# -----------------------------------------------------------
# 镜像配置
# -----------------------------------------------------------
IMAGE_REGISTRY=registry.cn-chengdu.aliyuncs.com
IMAGE_NAMESPACE=lmzjai
GPUSTACK_TAG=dev


# -----------------------------------------------------------
# 数据库配置（可选，默认使用嵌入式 SQLite）
# -----------------------------------------------------------
# GPUSTACK_DATABASE_URL=postgresql://user:password@postgres:5432/gpustack?sslmode=disable


# -----------------------------------------------------------
# PostgreSQL 配置
# -----------------------------------------------------------
# 如果使用 docker-compose 中自带的 PostgreSQL 容器，使用以下默认值即可
# 如果生产环境已有 PostgreSQL，请修改为已有实例的连接信息
# POSTGRES_USER=gpustack
# POSTGRES_PASSWORD=gpustack
# POSTGRES_DB=gpustack
# POSTGRES_PORT=5432
# POSTGRES_SSLMODE=disable
# POSTGRES_IMAGE=postgres:17

# 如果使用已有的外部 PostgreSQL，注释掉上面的值，并取消下面的注释
# POSTGRES_USER=your_pg_user
# POSTGRES_PASSWORD=your_pg_password
# POSTGRES_DB=gpustack
# POSTGRES_PORT=5432
# POSTGRES_SSLMODE=disable


# -----------------------------------------------------------
# 服务器基础配置
# -----------------------------------------------------------
# GPUSTACK_SERVER_EXTERNAL_URL=https://gpustack.example.com
# GPUSTACK_BOOTSTRAP_PASSWORD=admin123
# GPUSTACK_FORCE_AUTH_LOCALHOST=true
# GPUSTACK_DISABLE_UPDATE_CHECK=true
# GPUSTACK_ENABLE_CORS=true


# -----------------------------------------------------------
# OIDC / OAuth2 SSO 配置（推荐）
# 启用条件：GPUSTACK_OIDC_ISSUER 填写了有效值
# -----------------------------------------------------------
# IdP 的 Issuer URL，GPUStack 会自动访问 /.well-known/openid-configuration
GPUSTACK_OIDC_ISSUER=

# OIDC Client ID
GPUSTACK_OIDC_CLIENT_ID=

# OIDC Client Secret
GPUSTACK_OIDC_CLIENT_SECRET=

# 回调地址，必须为 <server-url>/auth/oidc/callback
GPUSTACK_OIDC_REDIRECT_URI=

# 跳过 UserInfo 端点，直接从 ID Token 解析用户信息（可选）
# GPUSTACK_OIDC_SKIP_USERINFO=false


# -----------------------------------------------------------
# SAML 2.0 SSO 配置（传统 IdP）
# 启用条件：GPUSTACK_SAML_IDP_SERVER_URL 填写了有效值
# -----------------------------------------------------------
# IdP SSO 服务 URL
GPUSTACK_SAML_IDP_SERVER_URL=

# IdP Single Logout 端点 URL（可选）
# GPUSTACK_SAML_IDP_LOGOUT_URL=

# IdP Entity ID
GPUSTACK_SAML_IDP_ENTITY_ID=

# IdP X.509 证书（PEM 格式）
GPUSTACK_SAML_IDP_X509_CERT=

# SP Entity ID
GPUSTACK_SAML_SP_ENTITY_ID=

# SP ACS 回调地址，必须为 <server-url>/auth/saml/callback
GPUSTACK_SAML_SP_ACS_URL=

# SP Single Logout Service URL（可选）
# GPUSTACK_SAML_SP_SLO_URL=

# SP X.509 证书（如需签名，可选）
# GPUSTACK_SAML_SP_X509_CERT=

# SP 私钥（如需签名，可选）
# GPUSTACK_SAML_SP_PRIVATE_KEY=

# SAML 属性命名空间前缀，简化属性名配置（可选）
# GPUSTACK_SAML_SP_ATTRIBUTE_PREFIX=

# SAML 安全设置（JSON 格式，可选）
# GPUSTACK_SAML_SECURITY={}


# -----------------------------------------------------------
# 外部认证用户字段映射（OIDC / SAML 通用）
# -----------------------------------------------------------
# 用户名字段映射
#   OIDC 示例: preferred_username
#   SAML 示例: emailaddress（需配合 attribute prefix）
GPUSTACK_EXTERNAL_AUTH_NAME=

# 全名字段映射
#   OIDC 示例: name
#   SAML 示例: name
GPUSTACK_EXTERNAL_AUTH_FULL_NAME=

# 头像 URL 字段映射（可选）
# GPUSTACK_EXTERNAL_AUTH_AVATAR_URL=

# 新用户默认禁用（可选，默认 false = 立即激活）
# GPUSTACK_EXTERNAL_AUTH_DEFAULT_INACTIVE=false

# 登出后重定向 Key（可选）
# GPUSTACK_EXTERNAL_AUTH_POST_LOGOUT_REDIRECT_KEY=


# SSL/TLS 配置
GPUSTACK_SSL_CERTFILE=/etc/gpustack/ssl/*.pem
GPUSTACK_SSL_KEYFILE=/etc/gpustack/ssl/*.key